[sqlfluff]
dialect = databricks
templater = jinja
exclude_rules = RF04,AM04,ST06,LT01,LT02,LT05,LT09,LT13,LT14,AL01,ST11,ST02,RF02,LT04
max_line_length = 120

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower
